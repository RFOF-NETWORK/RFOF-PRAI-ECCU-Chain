<script>
// Kryptographie & Kern-Logik
const cryptoLib = {
    async hash(data) {
        const msgBuffer = new TextEncoder().encode(data);
        const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
        return Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
    }
};

// Blockchain Speicher (Head & Body)
let chain = JSON.parse(localStorage.getItem('rfof_chain')) || [];

const vault = {
    current: null,
    async access() {
        const seed = document.getElementById('seed-phrase').value;
        if(seed.length < 5) return;
        const addr = "RFOF-" + (await cryptoLib.hash(seed)).substring(0, 20).toUpperCase();
        this.current = addr;
        this.sync();
        ui.showDashboard();
    },
    sync() {
        // Sucht alle Blöcke in der Blockchain nach dieser Wallet
        let balance = 0;
        chain.forEach(block => {
            if(block.body.miner === this.current) balance += block.body.amount;
        });
        document.getElementById('display-addr').innerText = this.current;
        document.getElementById('bal-eccu').innerText = balance.toFixed(8);
        document.getElementById('bal-euro').innerText = (balance * 2.5).toFixed(2) + " €";
        ui.renderChain();
    },
    generate() {
        const words = Array.from({length: 12}, () => Math.random().toString(36).substring(2, 7)).join(' ');
        document.getElementById('seed-phrase').value = words;
        alert("SPEICHERN FÜR IMMER:\n" + words);
    },
    logout() { location.reload(); }
};

const engine = {
    async mint() {
        if(!vault.current) return;
        const prevHash = chain.length > 0 ? chain[chain.length - 1].head.hash : "0".repeat(64);
        
        // BLOCK STRUKTUR: HEAD & BODY
        const block = {
            head: {
                index: chain.length,
                timestamp: Date.now(),
                prevHash: prevHash,
                hash: "" 
            },
            body: {
                miner: vault.current,
                amount: 0.00096093,
                energy: "8.5899 Joule",
                formula: "PZQQET-Axiom-1"
            }
        };

        block.head.hash = await cryptoLib.hash(JSON.stringify(block.body) + block.head.prevHash);
        chain.push(block);
        localStorage.setItem('rfof_chain', JSON.stringify(chain));
        vault.sync();
        ui.log(`BLOCK #${block.head.index} MINED & STORED PERMANENTLY.`);
    }
};

const ui = {
    showDashboard() {
        document.getElementById('auth-layer').style.display = 'none';
        document.getElementById('dashboard').style.display = 'block';
    },
    renderChain() {
        const track = document.getElementById('blockchain-track');
        track.innerHTML = "";
        chain.forEach(block => {
            const el = document.createElement('div');
            el.className = 'block-unit';
            el.innerHTML = `ID:${block.head.index}<br>ECCU`;
            el.onclick = () => this.inspect(block);
            track.appendChild(el);
        });
    },
    inspect(block) {
        const ins = document.getElementById('inspector');
        ins.style.display = 'block';
        document.getElementById('block-details').innerText = JSON.stringify(block, null, 2);
    },
    closeInspector() { document.getElementById('inspector').style.display = 'none'; },
    log(msg) {
        const c = document.getElementById('console-logs');
        c.innerHTML = `[${new Date().toLocaleTimeString()}] ${msg}<br>` + c.innerHTML;
    }
};

document.getElementById('mint-trigger').addEventListener('click', () => engine.mint());

// Timer Init
setInterval(() => {
    const d = new Date("August 14, 2026 00:00:00") - new Date();
    if(d<0) return;
    document.getElementById('global-timer').innerText = Math.floor(d/86400000) + "d " + new Date(d).toISOString().substr(11,8);
}, 1000);
</script>

<script>
/* ============================================================
   RFOF ↔ ECCU API BRIDGE
   Verbindet Minting (RFOF MAINNET) mit ECCU SUPPLY SYSTEM
   Speichert Supply global – unabhängig vom Login
   ============================================================ */

/* 1) GLOBALER ECCU-SUPPLY-SPEICHER */
let ECCU_SUPPLY = parseFloat(localStorage.getItem("eccu_supply_global")) || 0;

/* 2) API: Wird vom RFOF-Minting aufgerufen */
function api_registerMint(amountECCU) {
    // ECCU zur globalen Supply hinzufügen
    ECCU_SUPPLY += amountECCU;

    // Speichern
    localStorage.setItem("eccu_supply_global", ECCU_SUPPLY.toString());

    // Falls ECCU-UI existiert → live aktualisieren
    if (document.getElementById("total-supply-val")) {
        document.getElementById("total-supply-val").innerText =
            ECCU_SUPPLY.toFixed(8) + " ECCU";

        document.getElementById("euro-val").innerText =
            (ECCU_SUPPLY * 2.5).toLocaleString("de-DE", { minimumFractionDigits: 2 });

        // Fortschrittsbalken aktualisieren
        const sBar = document.getElementById("supply-bar");
        if (sBar) {
            let percent = Math.min((ECCU_SUPPLY / 100) * 100, 100);
            sBar.style.width = percent + "%";
            sBar.innerText = percent.toFixed(2) + "%";
        }
    }
}

/* 3) HOOK: RFOF-MINTING ABFANGEN UND AN API LEITEN */
(function() {
    const originalMint = engine.mint;

    engine.mint = async function() {
        const before = chain.length;

        // Original Mint ausführen
        await originalMint.apply(engine, arguments);

        const after = chain.length;

        // Wenn ein neuer Block erzeugt wurde → ECCU gutschreiben
        if (after > before) {
            const lastBlock = chain[chain.length - 1];

            // Menge aus Block übernehmen
            const minedECCU = lastBlock.body.amount;

            // API aufrufen
            api_registerMint(minedECCU);
        }
    };
})();

/* 4) ECCU-UI INITIALISIEREN (falls vorhanden) */
document.addEventListener("DOMContentLoaded", () => {
    if (document.getElementById("total-supply-val")) {
        document.getElementById("total-supply-val").innerText =
            ECCU_SUPPLY.toFixed(8) + " ECCU";

        document.getElementById("euro-val").innerText =
            (ECCU_SUPPLY * 2.5).toLocaleString("de-DE", { minimumFractionDigits: 2 });

        const sBar = document.getElementById("supply-bar");
        if (sBar) {
            let percent = Math.min((ECCU_SUPPLY / 100) * 100, 100);
            sBar.style.width = percent + "%";
            sBar.innerText = percent.toFixed(2) + "%";
        }
    }
});
</script>
